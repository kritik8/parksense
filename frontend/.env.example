# ParkSense AI — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── API Base URL ──────────────────────────────────────────────────────────
# The Vite dev server proxies /api/* to http://localhost:8000 automatically.
# You only need to set this if you are NOT using the proxy
# (e.g., deployed frontend hitting a remote backend).
#
# VITE_API_BASE=http://localhost:8000/api

# ── Optional: Override Bengaluru map center ────────────────────────────────
# VITE_MAP_LAT=12.9716
# VITE_MAP_LNG=77.5946
# VITE_MAP_ZOOM=12
